<div class="qps-section">
  <!-- Floating decorative mics -->
  <div class="qps-bg-deco">
    <svg class="deco-mic deco-mic--1" viewBox="0 0 60 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="18" y="4" width="24" height="52" rx="12" fill="currentColor"/>
      <path d="M8 48c0 12.15 9.85 22 22 22s22-9.85 22-22" stroke="currentColor" stroke-width="5" stroke-linecap="round" fill="none"/>
      <line x1="30" y1="70" x2="30" y2="90" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
      <line x1="18" y1="90" x2="42" y2="90" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
    </svg>
    <svg class="deco-mic deco-mic--2" viewBox="0 0 60 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="18" y="4" width="24" height="52" rx="12" fill="currentColor"/>
      <path d="M8 48c0 12.15 9.85 22 22 22s22-9.85 22-22" stroke="currentColor" stroke-width="5" stroke-linecap="round" fill="none"/>
      <line x1="30" y1="70" x2="30" y2="90" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
      <line x1="18" y1="90" x2="42" y2="90" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
    </svg>
    <svg class="deco-mic deco-mic--3" viewBox="0 0 60 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="18" y="4" width="24" height="52" rx="12" fill="currentColor"/>
      <path d="M8 48c0 12.15 9.85 22 22 22s22-9.85 22-22" stroke="currentColor" stroke-width="5" stroke-linecap="round" fill="none"/>
      <line x1="30" y1="70" x2="30" y2="90" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
      <line x1="18" y1="90" x2="42" y2="90" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
    </svg>
  </div>

  <div class="container py-5">
    <div class="row">
      <div class="col-md-10 mx-auto">
        <div class="qps-card">

          <!-- Top ribbon -->
          <div class="qps-ribbon">
            <span>VOTRE VOIX COMPTE</span>
          </div>

          <div class="qps-card-inner">

            <!-- Central mic hero -->
            <div class="qps-mic-hero">
              <div class="qps-mic-ring qps-mic-ring--outer"></div>
              <div class="qps-mic-ring qps-mic-ring--mid"></div>
              <div class="qps-mic-ring qps-mic-ring--inner"></div>
              <div class="qps-mic-icon">
                <svg viewBox="0 0 60 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="14" y="3" width="32" height="58" rx="16" fill="#3d1f0a"/>
                  <rect x="20" y="10" width="8" height="6" rx="3" fill="#f5c842" opacity="0.7"/>
                  <rect x="20" y="22" width="8" height="6" rx="3" fill="#f5c842" opacity="0.5"/>
                  <path d="M6 50c0 13.25 10.75 24 24 24s24-10.75 24-24" stroke="#3d1f0a" stroke-width="6" stroke-linecap="round" fill="none"/>
                  <line x1="30" y1="74" x2="30" y2="92" stroke="#3d1f0a" stroke-width="6" stroke-linecap="round"/>
                  <line x1="16" y1="92" x2="44" y2="92" stroke="#3d1f0a" stroke-width="6" stroke-linecap="round"/>
                </svg>
              </div>
            </div>

            <!-- Title -->
            <h2 class="qps-title">PROPOSEZ<br><em>VOTRE QUESTION</em></h2>

            <div class="qps-divider">
              <span class="qps-divider-dot"></span>
              <span class="qps-divider-dot"></span>
              <span class="qps-divider-dot"></span>
            </div>

            <p class="qps-subtitle">Posez vos questions, partagez vos préoccupations et faites entendre votre voix au sein de notre communauté</p>

            <% if user_signed_in? %>
              <!-- Utilisateur connecté -->
              <div class="qps-actions mt-4">
                <p class="qps-status qps-status--ok">
                  <span class="qps-status-dot"></span>
                  Vous êtes connecté
                </p>
                <%= link_to new_question_path, class: "qps-btn qps-btn--primary" do %>
                  <span class="qps-btn-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                  </span>
                  Poser ma question maintenant
                <% end %>
              </div>
            <% else %>
              <!-- Utilisateur non connecté -->
              <div class="qps-actions mt-4">
                <p class="qps-status qps-status--lock">
                  <span class="qps-lock-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
                  </span>
                  Connectez-vous pour proposer une question
                </p>
                <div class="qps-btn-group">
                  <%= link_to new_user_session_path, class: "qps-btn qps-btn--primary" do %>
                    <span class="qps-btn-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
                    </span>
                    Se connecter
                  <% end %>
                  <%= link_to new_user_registration_path, class: "qps-btn qps-btn--ghost" do %>
                    <span class="qps-btn-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM19 8v6M22 11h-6"/></svg>
                    </span>
                    Créer un compte
                  <% end %>
                </div>
                <p class="qps-security-note">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Compte sécurisé · Données protégées
                </p>
              </div>
            <% end %>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@400;500;600&display=swap');

  :root {
    --qps-yellow:      #f5c842;
    --qps-yellow-deep: #e0a800;
    --qps-brown:       #3d1f0a;
    --qps-brown-mid:   #6b3a1f;
    --qps-brown-light: #a0622d;
    --qps-cream:       #fdf6e3;
    --qps-cream-dark:  #f5e6c8;
  }

  /* ── Section wrapper ── */
  .qps-section {
    position: relative;
    overflow: hidden;
    background: var(--qps-cream);
    font-family: 'DM Sans', sans-serif;
    padding: 2rem 0;
  }

  /* ── Background floating mics ── */
  .qps-bg-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .deco-mic {
    position: absolute;
    color: var(--qps-yellow-deep);
    opacity: 0.08;
  }

  .deco-mic--1 { width: 140px; top: -20px; left: -30px; transform: rotate(-20deg); animation: floatMic 8s ease-in-out infinite; }
  .deco-mic--2 { width: 100px; top: 50%; right: -10px; transform: translateY(-50%) rotate(15deg); animation: floatMic 10s ease-in-out infinite reverse; }
  .deco-mic--3 { width: 80px; bottom: -10px; left: 40%; transform: rotate(5deg); animation: floatMic 12s ease-in-out infinite 2s; }

  @keyframes floatMic {
    0%, 100% { transform: translateY(0) rotate(var(--r, -20deg)); }
    50%       { transform: translateY(-18px) rotate(var(--r, -20deg)); }
  }

  .deco-mic--1 { --r: -20deg; }
  .deco-mic--2 { --r: 15deg; }
  .deco-mic--3 { --r: 5deg; }

  /* ── Card ── */
  .qps-card {
    position: relative;
    background: var(--qps-brown);
    border-radius: 24px;
    overflow: hidden;
    box-shadow:
      0 2px 0 var(--qps-yellow-deep),
      0 8px 40px rgba(61, 31, 10, 0.35),
      0 0 0 1px rgba(245, 200, 66, 0.25);
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.4s ease;
  }

  .qps-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(245,200,66,0.18) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(160,98,45,0.25) 0%, transparent 55%);
    pointer-events: none;
  }

  .qps-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 2px 0 var(--qps-yellow),
      0 20px 60px rgba(61, 31, 10, 0.5),
      0 0 0 1px rgba(245, 200, 66, 0.4);
  }

  /* ── Ribbon ── */
  .qps-ribbon {
    background: var(--qps-yellow);
    color: var(--qps-brown);
    text-align: center;
    padding: 7px 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  /* ── Card inner ── */
  .qps-card-inner {
    padding: 2.5rem 2rem 3rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  /* ── Mic hero ── */
  .qps-mic-hero {
    position: relative;
    width: 110px;
    height: 110px;
    margin: 0 auto 1.8rem;
  }

  .qps-mic-ring {
    position: absolute;
    border-radius: 50%;
    border: 2px solid var(--qps-yellow);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation: pulse-ring 3s ease-in-out infinite;
  }

  .qps-mic-ring--outer { width: 110px; height: 110px; opacity: 0.15; animation-delay: 0s; }
  .qps-mic-ring--mid   { width: 88px;  height: 88px;  opacity: 0.25; animation-delay: 0.5s; }
  .qps-mic-ring--inner { width: 68px;  height: 68px;  opacity: 0.4;  animation-delay: 1s; }

  @keyframes pulse-ring {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: var(--op, 0.25); }
    50%       { transform: translate(-50%, -50%) scale(1.08); opacity: calc(var(--op, 0.25) * 1.6); }
  }

  .qps-mic-ring--outer { --op: 0.15; }
  .qps-mic-ring--mid   { --op: 0.25; }
  .qps-mic-ring--inner { --op: 0.4; }

  .qps-mic-icon {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    background: var(--qps-yellow);
    border-radius: 50%;
    padding: 8px;
    box-shadow: 0 4px 20px rgba(245, 200, 66, 0.6);
  }

  .qps-mic-icon svg { width: 100%; display: block; }

  /* ── Title ── */
  .qps-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 900;
    color: var(--qps-cream);
    line-height: 1.1;
    margin-bottom: 0.8rem;
    letter-spacing: -0.01em;
  }

  .qps-title em {
    font-style: italic;
    color: var(--qps-yellow);
  }

  /* ── Divider dots ── */
  .qps-divider {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin: 1rem 0 1.2rem;
  }

  .qps-divider-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--qps-yellow);
    opacity: 0.6;
  }

  .qps-divider-dot:nth-child(2) { opacity: 1; transform: scale(1.3); }

  /* ── Subtitle ── */
  .qps-subtitle {
    color: rgba(253, 246, 227, 0.72);
    font-size: 0.93rem;
    max-width: 420px;
    margin: 0 auto 0.5rem;
    line-height: 1.65;
  }

  /* ── Status ── */
  .qps-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    margin-bottom: 1.2rem;
    padding: 6px 14px;
    border-radius: 100px;
  }

  .qps-status--ok {
    background: rgba(74, 222, 128, 0.12);
    color: #86efac;
    border: 1px solid rgba(74, 222, 128, 0.25);
  }

  .qps-status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 3px rgba(74,222,128,0.25);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .qps-status--lock {
    background: rgba(245, 200, 66, 0.1);
    color: var(--qps-yellow);
    border: 1px solid rgba(245, 200, 66, 0.25);
  }

  .qps-lock-icon svg { width: 16px; height: 16px; vertical-align: middle; }

  /* ── Buttons ── */
  .qps-btn-group {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .qps-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.6rem;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
    white-space: nowrap;
  }

  .qps-btn--primary {
    background: var(--qps-yellow);
    color: var(--qps-brown);
    box-shadow: 0 4px 16px rgba(245, 200, 66, 0.4);
  }

  .qps-btn--primary:hover {
    background: #ffe066;
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 8px 28px rgba(245, 200, 66, 0.55);
    color: var(--qps-brown);
    text-decoration: none;
  }

  .qps-btn--ghost {
    background: transparent;
    color: var(--qps-cream);
    border: 2px solid rgba(253, 246, 227, 0.35);
  }

  .qps-btn--ghost:hover {
    background: rgba(253, 246, 227, 0.1);
    border-color: rgba(253, 246, 227, 0.7);
    transform: translateY(-3px) scale(1.04);
    color: var(--qps-cream);
    text-decoration: none;
  }

  .qps-btn-icon {
    display: flex;
    align-items: center;
  }

  .qps-btn-icon svg {
    width: 16px;
    height: 16px;
  }

  /* ── Security note ── */
  .qps-security-note {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(253, 246, 227, 0.4);
    font-size: 0.78rem;
    margin-top: 0.5rem;
  }

  .qps-security-note svg { width: 13px; height: 13px; }

  /* ── Responsive ── */
  @media (max-width: 576px) {
    .qps-card-inner { padding: 2rem 1.2rem 2.5rem; }
    .qps-btn-group  { flex-direction: column; align-items: center; }
    .qps-btn        { width: 100%; justify-content: center; }
  }
</style>
