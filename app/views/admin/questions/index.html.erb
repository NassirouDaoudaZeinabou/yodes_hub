<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Gestion des Questions</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        :root {
            --amber-600: #d97706;
            --amber-700: #b45309;
            --bg-app: #f8fafc; 
            --bg-card: #ffffff;
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --border-neutral: #e2e8f0;
            --success: #10b981;
            --danger: #ef4444;
            --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        body { 
            background-color: var(--bg-app); 
            font-family: 'Inter', sans-serif;
            margin: 0;
            color: var(--text-primary);
        }

        .admin-dashboard {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        .dashboard-header { margin-bottom: 2rem; }

        .header-content {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-neutral);
        }

        .header-title-row { 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            margin-bottom: 1.5rem; 
        }

        .dashboard-title {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .btn-add-main {
            background: var(--amber-600);
            color: white;
            padding: 0.75rem 1.25rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.875rem;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);
        }

        .btn-add-main:hover {
            background: var(--amber-700);
            transform: translateY(-2px);
        }

        .stat-card {
            background: var(--bg-app);
            padding: 1rem 1.25rem;
            border-radius: 14px;
            display: flex;
            align-items: center;
            gap: 1rem;
            border: 1px solid var(--border-neutral);
        }

        .stat-value { font-size: 1.5rem; font-weight: 800; }
        .stat-label { font-size: 0.75rem; font-weight: 700; color: var(--text-secondary); }

        .table-container {
            background: var(--bg-card);
            border-radius: 20px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-neutral);
            overflow: hidden;
            margin-top: 2rem;
        }

        .admin-table { 
            width: 100%; 
            border-collapse: collapse; 
        }

        .admin-table thead {
            background: #fff;
            border-bottom: 1px solid var(--border-neutral);
        }

        .admin-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-secondary);
            letter-spacing: 0.05em;
        }

        .admin-table tbody tr {
            border-bottom: 1px solid var(--border-neutral);
            transition: all 0.2s;
        }

        .admin-table tbody tr:hover {
            background-color: var(--bg-app);
        }

        .admin-table td { 
            padding: 1rem 1.5rem; 
            vertical-align: middle; 
        }

        .question-cell { display: flex; flex-direction: column; gap: 0.5rem; }
        .question-content { font-weight: 700; font-size: 0.95rem; }
        .question-author { font-size: 0.75rem; color: var(--text-secondary); }

        .action-group { 
            display: flex; 
            justify-content: flex-end; 
            gap: 0.5rem; 
            flex-wrap: wrap;
        }

        .btn-action {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }

        .btn-view { color: #2563eb; background: #eff6ff; }
        .btn-view:hover { background: #dbeafe; }

        .btn-edit { color: var(--text-secondary); background: var(--bg-app); }
        .btn-edit:hover { background: #e8eef5; }

        .btn-delete { color: var(--text-secondary); background: var(--bg-app); }
        .btn-delete:hover { background: #fee2e2; color: #dc2626; }

        .btn-action svg { width: 18px; height: 18px; }

        .date-badge {
            font-size: 0.8rem;
            color: var(--text-secondary);
            background: var(--bg-app);
            padding: 0.25rem 0.75rem;
            border-radius: 8px;
        }

        .empty-state {
            padding: 3rem 2rem;
            text-align: center;
            color: var(--text-secondary);
        }

        .empty-state svg {
            width: 48px;
            height: 48px;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
    </style>
</head>
<body>

<div class="admin-dashboard">
    <header class="dashboard-header">
        <div class="header-content">
            <div class="header-title-row">
                <h1 class="dashboard-title">Gestion des Questions</h1>
                <%= link_to new_admin_question_path, class: 'btn-add-main' do %>
                    <span>+ Nouvelle Question</span>
                <% end %>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="stat-card">
                    <div>
                        <span class="stat-value"><%= @questions.count %></span>
                        <span class="stat-label">Questions au total</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div>
                        <span class="stat-value"><%= @questions.where('created_at >= ?', 7.days.ago).count %></span>
                        <span class="stat-label">Derniers 7 jours</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

   <% if @questions.empty? %>
        <div class="table-container">
            <div class="empty-state">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.3 0 4.601 1.08 5.877 2.5M7 17l2.75-2.75"></path>
                </svg>
                <p style="font-size: 1.1rem; margin-top: 1rem;">Aucune question enregistrée pour le moment.</p>
            </div>
        </div>
    <% else %>
        <div class="table-container">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Auteur</th>
                        <th>Date</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% @questions.each do |question| %>
                    <tr>
                        <td>
                            <div class="question-cell">
                                <span class="question-content">
                                    <%= truncate(question.content, length: 80) %>
                                </span>
                            </div>
                        </td>
                        <td>
                            <span class="question-author">
                                <%= question.user.email if question.user %>
                            </span>
                        </td>
                        <td>
                            <span class="date-badge">
                                <%= l(question.created_at, format: :short) %>
                            </span>
                        </td>
                        <td>
                            <div class="action-group">
                                <%= link_to admin_question_path(question), 
                                    class: 'btn-action btn-view', 
                                    title: 'Voir' do %>
                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                                    </svg>
                                <% end %>
                                
                                <%= link_to edit_admin_question_path(question), 
                                    class: 'btn-action btn-edit', 
                                    title: 'Modifier' do %>
                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                                    </svg>
                                <% end %>
                                
                                <%= button_to admin_question_path(question), 
                                    method: :delete, 
                                    data: { confirm: 'Êtes-vous sûr de vouloir supprimer cette question ?' }, 
                                    class: 'btn-action btn-delete', 
                                    title: 'Supprimer' do %>
                                    <svg fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                                    </svg>
                                <% end %>
                            </div>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    <% end %>
</div>

</body>
</html>
