<div class="admin-header">
  <h1>Question #<%= @question.id %></h1>
  <div class="actions">
    <%= link_to 'Modifier', edit_admin_question_path(@question), class: 'btn btn-primary' %>
    <%= link_to 'Retour', admin_questions_path, class: 'btn btn-secondary' %>
  </div>
</div>

<div class="question-detail">
  <div class="question-info">
    <div class="info-section">
      <h3 class="section-title">Contenu de la Question</h3>
      <p class="question-text"><%= simple_format(@question.content) %></p>
    </div>

    <div class="info-section">
      <h4 class="subsection-title">Informations</h4>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label">Auteur</span>
          <span class="info-value">
            <%= @question.user.email if @question.user %>
          </span>
        </div>
        <div class="info-item">
          <span class="info-label">Date de création</span>
          <span class="info-value">
            <%= l(@question.created_at, format: :long) %>
          </span>
        </div>
        <div class="info-item">
          <span class="info-label">Dernière modification</span>
          <span class="info-value">
            <%= l(@question.updated_at, format: :long) %>
          </span>
        </div>
        <div class="info-item">
          <span class="info-label">ID</span>
          <span class="info-value" style="font-family: monospace;"><%= @question.id %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid #e0e0e0;
  }

  .admin-header h1 {
    color: #2c3e50;
    font-size: 28px;
    margin: 0;
  }

  .actions {
    display: flex;
    gap: 12px;
  }

  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background: #c29600;
    color: white;
  }

  .btn-primary:hover {
    background: #a67c00;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(194, 150, 0, 0.3);
  }

  .btn-secondary {
    background: #6c757d;
    color: white;
  }

  .btn-secondary:hover {
    background: #5a6268;
  }

  .question-detail {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-top: 24px;
  }

  .question-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .info-section {
    background: white;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }

  .section-title {
    color: #2c3e50;
    font-size: 20px;
    margin: 0 0 16px 0;
    font-weight: 600;
    border-bottom: 2px solid #c29600;
    padding-bottom: 8px;
  }

  .subsection-title {
    color: #495057;
    font-size: 16px;
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .question-text {
    color: #495057;
    line-height: 1.7;
    margin: 0;
    white-space: pre-wrap;
    font-size: 1rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .info-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #64748b;
    letter-spacing: 0.05em;
  }

  .info-value {
    color: #1e293b;
    font-weight: 500;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .admin-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
